pipeline {
    agent any

    environment {
        IMAGE_NAME = "bkkrish007/spotify-devops"
        EC2_HOST = "ubuntu@3.6.224.208"
    }

    stages {

        /* ==============================
           BUILD APP INSIDE NODE CONTAINER
        ============================== */
        stage('Install & Build (Node Container)') {
            agent {
                docker {
                    image 'node:20'
                    args '-v /var/run/docker.sock:/var/run/docker.sock'
                }
            }
            steps {
                sh '''
                node -v
                npm install
                npm run build
                '''
            }
        }

        /* ==============================
           BUILD + PUSH (AMD64 IMAGE)
           FIX FOR MAC M1/M2/M3
        ============================== */
        stage('Build & Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {

                    sh '''
                    # Login DockerHub
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin

                    # Enable buildx (multi-arch builder)
                    docker buildx create --use || true

                    # Build image for EC2 architecture and push
                    docker buildx build \
                      --platform linux/amd64 \
                      -t $IMAGE_NAME:latest \
                      -f docker/Dockerfile \
                      --push .

                    docker logout
                    '''
                }
            }
        }

        /* ==============================
           DEPLOY TO AWS EC2
        ============================== */
        stage('Deploy to EC2') {
            steps {
                sshagent(['ec2-ssh-key']) {
                    sh '''
                    ssh -o StrictHostKeyChecking=no $EC2_HOST "
                        docker stop spotify || true &&
                        docker rm spotify || true &&
                        docker pull $IMAGE_NAME:latest &&
                        docker run -d -p 8081:80 --name spotify $IMAGE_NAME:latest
                    "
                    '''
                }
            }
        }
    }

    /* ==============================
       CLEANUP
    ============================== */
    post {
        always {
            cleanWs()
        }
    }
}