pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Build Application') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t spotify-clone -f docker/Dockerfile .'
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                docker rm -f spotify || true
                docker ps -aq --filter "publish=8081" | xargs -r docker rm -f
                docker run -d -p 8081:80 --name spotify spotify-clone
                '''
            }
        }

        stage('Deploy to AWS EC2') {
            steps {
                sh '''
                echo "Deploying to AWS EC2..."

            ssh -o StrictHostKeyChecking=no ubuntu@13.200.246.186 '
                docker rm -f spotify || true
                docker run -d -p 8081:80 --name spotify spotify-clone
            '
            '''
           }
        }
    }
}